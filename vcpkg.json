{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "flamerobin",
  "version-semver": "26.6.10",
  "description": "FlameRobin is a database administration tool for Firebird DBMS",
  "homepage": "https://www.flamerobin.org",
  "license": "MIT",
  "supports": "(windows & !uwp) | linux | osx",
  "dependencies": [
    "boost-dll",
    "boost-filesystem",
    "boost-multiprecision",
    "boost-test",
    "firebird",
    {
      "name": "fb-cpp",
      "features": [
        "boost-dll",
        "boost-multiprecision"
      ]
    },
    "icu",
    {
      "name": "gtk3",
      "features": [
        "wayland"
      ],
      "platform": "linux | freebsd | openbsd"
    },
    {
      "name": "wxwidgets",
      "features": [
        "webview",
        "secretstore"
      ]
    },
    "pcre2",
    {
      "name": "lexilla",
      "platform": "windows"
    },
    {
      "name": "scintilla",
      "platform": "windows"
    }
  ],
  "overrides": [
    {
      "name": "boost-dll",
      "version": "1.90.0"
    },
    {
      "name": "boost-filesystem",
      "version": "1.90.0"
    },
    {
      "name": "boost-multiprecision",
      "version": "1.90.0"
    },
    {
      "name": "boost-test",
      "version": "1.90.0"
    },
    {
      "name": "firebird",
      "version": "5.0.4"
    },
    {
      "name": "fb-cpp",
      "version": "0.0.4"
    },
    {
      "name": "icu",
      "version": "78.1"
    }
  ]
}
