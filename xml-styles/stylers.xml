<?xml version="1.0" encoding="Windows-1252"?>
<!--
    stylers.xml  —  FlameRobin default LIGHT theme
    Redesigned 2026-07-07 (fixes #642): replaced neon/low-contrast colours
    with a calm, professional palette inspired by GitHub Light / VS Code Light+.
    All foreground colours achieve WCAG AA contrast (≥4.5:1) on white.
-->
<Flamerobin>
    <LexerStyles>
        <!-- ═══ DIFF ══════════════════════════════════════════════════════ -->
        <LexerType name="diff" desc="DIFF" ext="">
            <!-- Default plain text: near-black on white -->
            <WordsStyle name="DEFAULT"  styleID="0" fgColor="1F2328" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Comment / context lines: muted slate -->
            <WordsStyle name="COMMENT"  styleID="1" fgColor="57606A" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Command / hunk header: deep blue -->
            <WordsStyle name="COMMAND"  styleID="2" fgColor="0550AE" bgColor="FFFFFF" fontName="" fontStyle="1" fontSize="" caseVisible="0"/>
            <!-- Position / @@ line: purple-indigo -->
            <WordsStyle name="HEADER"   styleID="3" fgColor="6639BA" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Position marker: muted teal, replaces neon orange -->
            <WordsStyle name="POSITION" styleID="4" fgColor="0E7C5F" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Deleted lines: deep red, no neon -->
            <WordsStyle name="DELETED"  styleID="5" fgColor="82071E" bgColor="FFEBE9" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Added lines: deep green -->
            <WordsStyle name="ADDED"    styleID="6" fgColor="116329" bgColor="DAFBE1" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
        </LexerType>

        <!-- ═══ SQL ═══════════════════════════════════════════════════════ -->
        <LexerType name="sql" desc="SQL" ext="">
            <!-- Reserved keywords (SELECT, FROM, WHERE …): deep blue-indigo, bold -->
            <WordsStyle name="KEYWORD"      styleID="5"  fgColor="0550AE" bgColor="FFFFFF" fontName="" fontStyle="1" fontSize="" caseVisible="0"/>
            <!-- User-defined names / functions: same hue, regular weight -->
            <WordsStyle name="USER1"        styleID="16" fgColor="0550AE" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Data-type / secondary keywords: muted purple-indigo -->
            <WordsStyle name="KEYWORD2"     styleID="19" fgColor="6639BA" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Numbers: warm teal (replaces neon orange FF8000) -->
            <WordsStyle name="NUMBER"       styleID="4"  fgColor="0E7C5F" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- String literals: earthy brown/sienna -->
            <WordsStyle name="STRING"       styleID="6"  fgColor="953800" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Alternative quote strings -->
            <WordsStyle name="STRING2"      styleID="7"  fgColor="953800" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Operators (+ - * / = …): dark charcoal, bold -->
            <WordsStyle name="OPERATOR"     styleID="10" fgColor="393A34" bgColor="FFFFFF" fontName="" fontStyle="1" fontSize="" caseVisible="0"/>
            <!-- Block comments: medium slate-green -->
            <WordsStyle name="COMMENT"      styleID="1"  fgColor="57606A" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Line comments (--): same slate-green -->
            <WordsStyle name="COMMENT LINE" styleID="2"  fgColor="57606A" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Doc comments: slightly warmer slate -->
            <WordsStyle name="COMMENT DOC"  styleID="3"  fgColor="57606A" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
            <!-- Q-operator / quoted identifiers: muted slate -->
            <WordsStyle name="Q OPERATOR"   styleID="24" fgColor="57606A" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
        </LexerType>

        <!-- ═══ SEARCH RESULT ════════════════════════════════════════════ -->
        <LexerType name="searchResult" desc="Search result" ext="">
            <!-- Section header: deep blue on pale blue-grey tint -->
            <WordsStyle name="Search Header"                  styleID="1" fgColor="0550AE" bgColor="DDE8F5" fontName="" fontStyle="1" fontSize=""/>
            <!-- File path header: deep green on pale mint -->
            <WordsStyle name="File Header"                    styleID="2" fgColor="116329" bgColor="DCFCE7" fontName="" fontStyle="1" fontSize=""/>
            <!-- Line numbers: medium slate (replaces neon FF8040) -->
            <WordsStyle name="Line Number"                    styleID="3" fgColor="57606A" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize=""/>
            <!-- Matched word: deep amber on soft yellow, no pure red -->
            <WordsStyle name="Hit Word"                       styleID="4" fgColor="7D4E00" bgColor="FFF3C0" fontName="" fontStyle="0" fontSize=""/>
            <!-- Active result row tint: very subtle blue wash -->
            <WordsStyle name="Current line background colour" styleID="6" bgColor="EFF4FB"/>
        </LexerType>
    </LexerStyles>

    <GlobalStyles>
        <!-- Attention : Don't modify the name of styleID="0" -->
        <!-- Global override: near-black text on clean white, Consolas (cleaner than Courier New) -->
        <WidgetStyle name="Global override"            styleID="0"    fgColor="1F2328" bgColor="FFFFFF" fontName="Consolas" fontStyle="0" fontSize="10" caseVisible="0"/>
        <!-- Default Scintilla slot 32 -->
        <WidgetStyle name="Default Style"              styleID="32"   fgColor="1F2328" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
        <!-- Indent guides: very light grey -->
        <WidgetStyle name="Indent guideline style"     styleID="37"   fgColor="D0D7DE" bgColor="FFFFFF" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
        <!-- Matched brace: deep green highlight (replaces pure red) -->
        <WidgetStyle name="Brace highlight style"      styleID="34"   fgColor="116329" bgColor="DCFCE7" fontName="" fontStyle="1" fontSize="" caseVisible="0"/>
        <!-- Unmatched brace: deep red -->
        <WidgetStyle name="Bad brace colour"           styleID="35"   fgColor="82071E" bgColor="FFEBE9" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
        <!-- Current line highlight: very pale blue wash -->
        <WidgetStyle name="Current line background colour" styleID="0" bgColor="F0F6FF"/>
        <!-- Selection: soft warm grey (replaces flat C0C0C0) -->
        <WidgetStyle name="Selected text colour"       styleID="0"    bgColor="BDD7F5"/>
        <!-- Text cursor: deep indigo (replaces neon 8000FF) -->
        <WidgetStyle name="Caret colour"               styleID="2069" fgColor="0550AE"/>
        <!-- Column guide line: very light grey -->
        <WidgetStyle name="Edge colour"                styleID="0"    fgColor="D0D7DE"/>
        <!-- Line number gutter: medium grey on very light grey -->
        <WidgetStyle name="Line number margin"         styleID="33"   fgColor="57606A" bgColor="F6F8FA" fontName="" fontStyle="0" fontSize="" caseVisible="0"/>
        <!-- Fold markers: medium grey on near-white -->
        <WidgetStyle name="Fold"                       styleID="0"    fgColor="8C959F" bgColor="F6F8FA"/>
        <!-- Active fold marker: deep blue (replaces pure red) -->
        <WidgetStyle name="Fold active"                styleID="0"    fgColor="0550AE"/>
        <!-- Fold margin background: off-white -->
        <WidgetStyle name="Fold margin"                styleID="0"    fgColor="8C959F" bgColor="F6F8FA"/>
        <!-- Whitespace dots: muted warm grey (replaces neon FFB56A) -->
        <WidgetStyle name="White space symbol"         styleID="0"    fgColor="AFBAC4"/>
        <!-- Smart highlight: soft teal wash (replaces pure 00FF00) -->
        <WidgetStyle name="Smart HighLighting"         styleID="29"   bgColor="C8F5E8"/>
        <!-- Find mark: soft amber (replaces pure FF0000) -->
        <WidgetStyle name="Find Mark Style"            styleID="31"   bgColor="FFD966"/>
        <!-- Mark styles: calmer, accessible tones -->
        <WidgetStyle name="Mark Style 1"               styleID="25"   bgColor="BDD7F5"/>
        <WidgetStyle name="Mark Style 2"               styleID="24"   bgColor="FFE0A0"/>
        <WidgetStyle name="Mark Style 3"               styleID="23"   bgColor="FFF3C0"/>
        <WidgetStyle name="Mark Style 4"               styleID="22"   bgColor="E0D4F7"/>
        <WidgetStyle name="Mark Style 5"               styleID="21"   bgColor="C8F5E8"/>
        <!-- Incremental search highlight: soft blue -->
        <WidgetStyle name="Incremental highlight all"  styleID="28"   bgColor="BDD7F5"/>
        <!-- Tag-match: soft violet -->
        <WidgetStyle name="Tags match highlighting"    styleID="27"   bgColor="E0D4F7"/>
        <!-- Tag attribute: soft yellow -->
        <WidgetStyle name="Tags attribute"             styleID="26"   bgColor="FFF3C0"/>
        <!-- Tab indicator: golden amber (kept, it's the brand colour) -->
        <WidgetStyle name="Active tab focused indicator"   styleID="0" fgColor="B65B00"/>
        <!-- Unfocused tab indicator: muted amber -->
        <WidgetStyle name="Active tab unfocused indicator" styleID="0" fgColor="D4874A"/>
        <!-- Active tab text: near-black -->
        <WidgetStyle name="Active tab text"            styleID="0"    fgColor="1F2328"/>
        <!-- Inactive tabs: medium grey on light grey -->
        <WidgetStyle name="Inactive tabs"              styleID="0"    fgColor="57606A" bgColor="EAEEF2"/>
        <!-- Hovered URL: deep blue -->
        <WidgetStyle name="URL hovered"                styleID="0"    fgColor="0550AE"/>
        <!-- Document map: deep blue on white -->
        <WidgetStyle name="Document map"               styleID="0"    fgColor="0550AE" bgColor="FFFFFF"/>
        <!-- Log messages (used by ExecuteSqlFrame stats pane) -->
        <WidgetStyle name="Log message important"      styleID="1"    fgColor="0550AE"/>
        <WidgetStyle name="Log message error"          styleID="2"    fgColor="82071E"/>
    </GlobalStyles>
</Flamerobin>
